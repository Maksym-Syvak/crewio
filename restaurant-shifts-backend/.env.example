# --- App ---
PORT=3000
NODE_ENV=development
FRONTEND_URL=https://your-mini-app.vercel.app

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=restaurant_shifts

# --- Auth ---
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# --- Telegram ---
# IMPORTANT: Never commit a real token. If a token was ever pasted into a
# chat, doc, or commit, revoke it via BotFather (/mybots -> API Token ->
# Revoke) and put the NEW token here only.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change_me

# --- Google ---
GOOGLE_PLACES_API_KEY=
GOOGLE_MAPS_API_KEY=
